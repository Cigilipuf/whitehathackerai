# WhiteHatHacker AI - Ortam Değişkenleri Şablonu
# Kopyala: cp .env.example .env && düzenle

# ============================================================
# LLM Backend — Remote (LM Studio / OpenAI-uyumlu API)
# İki model aynı LM Studio üzerinde çalışıyorsa aynı URL kullanılır.
# GÜVENLİK: Farklı makinedeyse SSH tüneli önerilir:
#   ssh -f -N -L 1239:127.0.0.1:1239 user@LM_STUDIO_IP
# Sonra URL olarak http://127.0.0.1:1239 kullanın.
# ============================================================
WHAI_PRIMARY_API_URL=http://127.0.0.1:1239
WHAI_SECONDARY_API_URL=http://127.0.0.1:1239
WHAI_PRIMARY_API_KEY=
WHAI_SECONDARY_API_KEY=

# ============================================================
# LLM Backend — Local (llama-cpp-python, opsiyonel fallback)
# Remote kullanılıyorsa boş bırakılabilir.
# ============================================================
WHAI_PRIMARY_MODEL_PATH=
WHAI_SECONDARY_MODEL_PATH=

# ============================================================
# SSH Tunnel to Brain (Mac with LM Studio)
# ============================================================
WHAI_SSH_REMOTE_HOST=your_lm_studio_ip
WHAI_SSH_REMOTE_USER=your_ssh_username
WHAI_SSH_REMOTE_PORT=1239
WHAI_SSH_LOCAL_PORT=1239
WHAI_SSH_KEY_PATH=$HOME/.ssh/your_key_name

# ============================================================
# Runtime
# ============================================================
WHAI_MODE=semi-autonomous
WHAI_SCAN_PROFILE=balanced
WHAI_LOG_LEVEL=INFO
WHAI_MAX_PARALLEL_TOOLS=5
WHAI_GPU_LAYERS=-1

# ============================================================
# Bug Bounty Platform API Keys
# ============================================================
HACKERONE_API_TOKEN=
HACKERONE_API_USERNAME=
BUGCROWD_API_TOKEN=

# ============================================================
# OSINT API Keys
# ============================================================
SHODAN_API_KEY=
CENSYS_API_ID=
CENSYS_API_SECRET=
GITHUB_TOKEN=
VIRUSTOTAL_API_KEY=
SECURITYTRAILS_API_KEY=

# ============================================================
# Notification Channels
# ============================================================
SLACK_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=

# ============================================================
# Database
# ============================================================
DATABASE_URL=output/whai.db

# ============================================================
# Redis (Opsiyonel - cache & queue)
# ============================================================
REDIS_URL=redis://localhost:6379/0

# ============================================================
# Interactsh (OOB Testing)
# ============================================================
INTERACTSH_SERVER=
INTERACTSH_TOKEN=
